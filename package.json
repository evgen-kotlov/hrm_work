{
    "name": "hr-system-backend",
    "version": "1.0.0",
    "description": "Backend для HR Management System",
    "main": "server.js",
    "type": "module",
    "scripts": {
      "start": "node server.js",
      "dev": "nodemon server.js",
      "test": "playwright test",
      "test:smoke": "playwright test --grep '@smoke'",
      "test:regress": "playwright test --grep '@regress",
      "test:headed": "playwright test --headed",
      "report": "playwright show-report",      
      "report:allure:generate": "allure generate allure-results -o allure-report --clean",
      "report:allure:open": "allure open allure-report",
      "report:allure:serve": "allure serve allure-results",
    
      "clean": "rimraf allure-results allure-report playwright-report test-results"

    },
    "dependencies": {
      "express": "^4.18.2",
      "cors": "^2.8.5",
      "multer": "^1.4.5-lts.1",
      "jsonwebtoken": "^9.0.2",
      "bcryptjs": "^2.4.3"
    },
    "devDependencies": {
      "@faker-js/faker": "10.3.0",
        "@playwright/test": "^1.58.2",
        "@types/node": "^25.3.2",
        "@types/wait-on": "^5.3.4",
        "allure-commandline": "2.37.0",
        "allure-playwright": "3.6.0",
        "nodemon": "^3.0.1",
        "typescript": "^5.2.2",
        "wait-on": "^7.2.0"
    }
  }